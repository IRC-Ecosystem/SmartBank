# =============================================
# SmartBank CBDC - Environment Template
# Copy this file to .env and fill in real values
# DO NOT commit .env with real credentials
# =============================================

# --- MySQL Database ---
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=central_bank_core
MYSQL_USER=central_bank
MYSQL_PASSWORD=change_me_db_password

# --- Shared Backend Security ---
# Used by internal service-to-service calls. Keep these values identical for
# services that communicate with each other.
JWT_SECRET=change_me_shared_jwt_secret_min_32_chars
SERVICE_TOKEN=change_me_shared_service_token_min_32_chars

# --- Central Bank Core (Port 3000) ---
CB_DATABASE_URL=mysql://central_bank:change_me_db_password@mysql:3306/central_bank_core
CB_JWT_SECRET=change_me_jwt_secret_min_32_chars
CB_PORT=3000
CB_TOTAL_MONEY_SUPPLY=1000000000
CB_INITIAL_USER_BALANCE=50000
CB_INITIAL_DISTRIBUTION_MAX_BPS=200
CB_RESERVE_MINIMUM_BPS=9800
CB_BASIC_WALLET_BALANCE_LIMIT=100000
CB_DAILY_TRANSACTION_LIMIT=10
CB_TRANSACTION_COOLDOWN_SECONDS=10

# --- Wallet Backend (Port 6969) ---
WALLET_PORT=6969
WALLET_NODE_ENV=development
WALLET_JWT_SECRET=change_me_jwt_secret_min_32_chars
WALLET_JWT_ACCESS_EXPIRES=3600
WALLET_JWT_REFRESH_EXPIRES=604800
WALLET_DB_HOST=mysql
WALLET_DB_PORT=3306
WALLET_DB_USER=central_bank
WALLET_DB_PASSWORD=change_me_db_password
WALLET_DB_NAME=central_bank_core
WALLET_USE_IN_MEMORY_DB=false
WALLET_CENTRAL_BANK_CORE_URL=http://central-bank:3000
WALLET_MOCK_CENTRAL_BANK=false
WALLET_COOLDOWN_SECONDS=10
WALLET_DAILY_LIMIT_COUNT=10

# CORS - Comma-separated allowed origins (no spaces)
# Examples:
#   - http://localhost:3001,http://localhost:6969  (local dev)
#   - https://smartbank.example.com               (production)
WALLET_CORS_ORIGINS=http://localhost:3001,http://localhost:6969,http://localhost:5173

# --- Frontend (Port 3001) ---
VITE_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Target server untuk fitur "Try it out" pada /api-docs
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000
NEXT_PUBLIC_CENTRAL_BANK_URL=http://localhost:3000
NEXT_PUBLIC_WALLET_URL=http://localhost:6969
NEXT_PUBLIC_CONNECTOR_URL=http://localhost:5000

# --- Connector (Port 5000) ---
# Local/Laragon defaults. For Docker, docker-compose overrides hostnames.
CONNECTOR_PORT=5000
CONNECTOR_NODE_ENV=development
CONNECTOR_DATABASE_HOST=127.0.0.1
CONNECTOR_DATABASE_PORT=3306
CONNECTOR_DATABASE_NAME=connector_db
CONNECTOR_CENTRAL_BANK_URL=http://127.0.0.1:3000
CONNECTOR_RATE_LIMIT_DEFAULT_RPS=50
CONNECTOR_ADMIN_KEY=change_me_connector_admin_key_min_32_chars
CONNECTOR_AUDIT_HMAC_SECRET=change_me_connector_audit_hmac_secret_min_32_chars
CONNECTOR_ADMIN_ALLOWED_IPS=127.0.0.1,::1,172.*
# Optional full URL override. Otherwise MYSQL_USER and MYSQL_PASSWORD above
# are used with the Connector database host, port, and name.
# CONNECTOR_DATABASE_URL=mysql://user:password@127.0.0.1:3306/connector_db

# --- Development Options ---
# Set to true only in local dev to seed staff test accounts
ENABLE_STAFF_SEED=false
